[codespell]
# Skip generated/binary/vendored paths that would produce noise or false hits.
skip = .git,go.sum,dist,tools/test-mocks/*/go.sum,*.svg,*.png,*.jpg
# Silence legitimate terms codespell flags. libell = iwd's ell library ("no
# libell needed"), not a misspelling of "libel".
ignore-words-list = libell
