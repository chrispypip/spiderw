#-------------------------------------------------------------------------------
# spiderw - Dockerfile.dev
#
# Description:  Provieds a reproducible Go development environment with DBus
#               support, matching the local and devcontainer workflows.
#               The image contains everything needed to develop and run mock
#               tests for the spiderw project.
# Usage:
#   docker-compose up --build
#
# Notes:
#   - The build stage caches Go modules for fast rebuilds.
#   - The project source is mounted at /workspace.
#-------------------------------------------------------------------------------
FROM ubuntu:24.04@sha256:1c4cc37c10c4678fd5369d172a4e079af8a28a6e6f724647ccaa311b4801c3c9

ENV DEBIAN_FRONTEND=noninteractive

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

# --------------------------------------------------------
# Create file indicating running in container
# --------------------------------------------------------
RUN echo "spiderw-dev" > /etc/spiderw-dev-container

RUN DEBIAN_FRONTEND=noninteractive apt-get update && \
  apt-get install -y --no-install-recommends \
  bash \
  build-essential \
  ca-certificates \
  codespell \
  curl \
  dbus \
  dbus-x11 \
  direnv \
  file \
  git \
  hostapd \
  iproute2 \
  iw \
  less \
  libglib2.0-dev \
  lsof \
  neovim \
  net-tools \
  pkg-config \
  psmisc \
  python3 \
  python3-dbus \
  python3-dbusmock \
  python3-pip \
  socat \
  sudo \
  vim \
  \
  && rm -rf /var/lib/apt/lists/*

# ----------------------------
# Install Go (pinned)
# ----------------------------
ARG GO_VERSION=1.26.4
RUN curl -fsSL https://go.dev/dl/go${GO_VERSION}.linux-amd64.tar.gz \
  | tar -xz -C /usr/local

# ---------------------------------------------------------------------------
# Create dev user
# ---------------------------------------------------------------------------
RUN useradd -m dev && echo "dev ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

COPY docker_entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

# Setup Go cache
RUN mkdir -p /home/dev/.cache/go-build /home/dev/go/pkg/mod && \
  chown -R dev:dev /home/dev

USER dev
WORKDIR /workspace

# Go env
ENV GOPATH=/home/dev/go
ENV PATH=/usr/local/go/bin:${GOPATH}/bin:${PATH}

# Pin golangci-lint to a v2 release so it matches the v2 .golangci.yml schema
# and the version used in CI. Note the `/v2` module path: golangci-lint v2 is a
# distinct module, and the legacy path's @latest still resolves to v1.
ARG GOLANGCI_LINT_VERSION=v2.12.2
RUN go install golang.org/x/tools/cmd/goimports@latest && \
  go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@${GOLANGCI_LINT_VERSION}

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
