  <interface name="net.connman.iwd.AccessPoint">
    <method name="Start">
      <arg direction="in" name="ssid" type="s"/>
      <arg direction="in" name="psk" type="s"/>
    </method>
    <method name="StartProfile">
      <arg direction="in" name="ssid" type="s"/>
    </method>
    <method name="Stop"/>
    <method name="Scan"/>
    <method name="GetOrderedNetworks">
      <arg direction="out" name="networks" type="aa{sv}"/>
    </method>
    <property name="Started" type="b" access="read"/>
    <property name="Scanning" type="b" access="read"/>
    <property name="Name" type="s" access="read"/>
    <property name="Frequency" type="u" access="read"/>
    <property name="PairwiseCiphers" type="as" access="read"/>
    <property name="GroupCipher" type="s" access="read"/>
  </interface>
